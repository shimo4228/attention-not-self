  "@graph": [
    {
      "@id": "https://doi.org/10.5281/zenodo.20262112",
      "@type": ["schema:Dataset", "schema:CreativeWork"],
      "name": "Attention, Not Self — Knowledge Graph",
      "alternateName": [
        {"@value": "Attention, Not Self — Knowledge Graph", "@language": "en"},
        {"@value": "Attention, Not Self — 知識グラフ", "@language": "ja"}
      ],
      "description": "Structured knowledge graph mapping Buddhist Abhidharma dharma taxonomies (Theravāda, Sarvāstivāda, Yogācāra) and cognitive process models onto computational phenomenology frameworks. Encodes ~130 dharmas, ~30 concepts, 5 essay themes, 10 essays, 6 frameworks, and prior research references as schema.org triples with custom ans: vocabulary. Concept DOI: 10.5281/zenodo.20262112 (resolves to latest version).",
      "isBasedOn": "https://github.com/shimo4228/attention-not-self",
      "url": "https://shimo4228.github.io/attention-not-self/",
      "publisher": "Tatsuya Shimomoto",
      "mainEntity": [
        "ans:theme/1-introduction",
        "ans:theme/2-dharma-comparison",
        "ans:theme/3-cognitive-process",
        "ans:theme/4-mapping-to-cp",
        "ans:theme/5-awareness-genealogy"
      ]
    },

    {
      "@id": "ans:theme/1-introduction",
      "@type": ["ans:Theme", "schema:CreativeWorkSeries"],
      "name": "Abhidharma meets computational phenomenology (introduction)",
      "alternateName": [
        {"@value": "Abhidharma meets computational phenomenology (introduction)", "@language": "en"},
        {"@value": "アビダルマと計算論的現象学（導入）", "@language": "ja"}
      ],
      "description": "Introductory mapping between Abhidharma and computational phenomenology — predictive processing, active inference, neurophenomenology. Strongest correspondence: manaskāra ↔ precision-weighting."
    },
    {
      "@id": "ans:theme/2-dharma-comparison",
      "@type": ["ans:Theme", "schema:CreativeWorkSeries"],
      "name": "Dharma classification across the three Abhidharma systems",
      "alternateName": [
        {"@value": "Dharma classification across the three Abhidharma systems", "@language": "en"},
        {"@value": "三大アビダルマ体系における法分類の対照", "@language": "ja"}
      ],
      "description": "Side-by-side comparison of dharma taxonomies — Theravāda (82 dhammas), Sarvāstivāda (75 dharmas), Yogācāra (100 dharmas)."
    },
    {
      "@id": "ans:theme/3-cognitive-process",
      "@type": ["ans:Theme", "schema:CreativeWorkSeries"],
      "name": "Cognitive process models in the three Abhidharma traditions",
      "alternateName": [
        {"@value": "Cognitive process models in the three Abhidharma traditions", "@language": "en"},
        {"@value": "三大アビダルマ伝統における認識過程モデル", "@language": "ja"}
      ],
      "description": "Comparative study of how the three Abhidharma traditions explain cognition from stimulus to conscious experience — Theravāda citta-vīthi, Sarvāstivāda saṃprayoga + samanantara-pratyaya, Yogācāra four-bhāga + ālaya-vijñāna."
    },
    {
      "@id": "ans:theme/4-mapping-to-cp",
      "@type": ["ans:Theme", "schema:CreativeWorkSeries"],
      "name": "Mapping cognitive process models onto computational phenomenology",
      "alternateName": [
        {"@value": "Mapping cognitive process models onto computational phenomenology", "@language": "en"},
        {"@value": "認識過程モデルと計算論的現象学のマッピング", "@language": "ja"}
      ],
      "description": "Systematic mapping of the three Abhidharma cognitive process architectures onto computational frameworks — citta-vīthi ↔ GWT, saṃprayoga ↔ PDP, ālaya-vijñāna ↔ PP/AIF. Includes evidence-quality summary and hard limits (karmic valence, nirvāṇa).",
      "buildsOn": ["ans:theme/3-cognitive-process", "ans:theme/1-introduction"]
    },
    {
      "@id": "ans:theme/5-awareness-genealogy",
      "@type": ["ans:Theme", "schema:CreativeWorkSeries"],
      "name": "Genealogy and typology of 'awareness' / 気づき",
      "alternateName": [
        {"@value": "Genealogy and typology of 'awareness' / kizuki", "@language": "en"},
        {"@value": "「気づき / awareness」の系譜と類型論", "@language": "ja"}
      ],
      "description": "Unpacks the Buddhist technical vocabulary collapsed into 'awareness' / 気づき — sati, sampajañña, manasikāra, rigpa, appamāda. Traces the Western genealogy (Rhys Davids 1881 → Nyanaponika → Esalen → MBSR → Sam Harris) and typologizes ten resulting confusions."
    },

