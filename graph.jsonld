    {
      "@id": "ans:concept/manaskara-attention",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "manaskāra as attention",
      "alternateName": [
        {"@value": "manaskāra (attention as direction-fixing)", "@language": "en"},
        {"@value": "作意（注意：心を対象に向ける作用）", "@language": "ja"}
      ],
      "description": "Central mapping target. The universal mental factor manaskāra functions as attention — selecting which sense-object or mental content becomes salient. Maps strongly onto precision-weighting in predictive processing / active inference.",
      "mapsTo": "ans:framework/pp",
      "discussesIn": [
        "https://github.com/shimo4228/attention-not-self/blob/main/Abhidharma%20Meets%20Computational%20Phenomenology.md",
        "https://github.com/shimo4228/attention-not-self/blob/main/Awareness%20-%20A%20Genealogy%20and%20Typology.md"
      ]
    },
    {
      "@id": "ans:concept/citta-vithi",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "citta-vīthi (cognitive process)",
      "alternateName": [
        {"@value": "citta-vīthi — Theravāda 17-moment cognitive process", "@language": "en"},
        {"@value": "心路過程（上座部の17刹那認識過程）", "@language": "ja"}
      ],
      "description": "Theravāda's serial 17-moment model of how a single sense-object is processed: bhavaṅga → āvajjana → sense-consciousness → receiving → investigating → determining → 7 javana → 2 registration → back to bhavaṅga. Maps onto Global Workspace Theory's serial ignition.",
      "mapsTo": {"@id": "ans:framework/gwt", "evidenceQuality": "strong"},
      "discussesIn": "https://github.com/shimo4228/attention-not-self/blob/main/Three%20Abhidharma%20Models%20of%20Cognition.md"
    },
    {
      "@id": "ans:concept/javana",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "javana (impulsion)",
      "alternateName": [
        {"@value": "javana — impulsion phase of citta-vīthi (7 moments)", "@language": "en"},
        {"@value": "速行（javana：心路過程における7刹那の能動相）", "@language": "ja"}
      ],
      "description": "Karmically active phase of citta-vīthi where wholesome or unwholesome volition arises. Functional parallel to predictive top-down inference."
    },
    {
      "@id": "ans:concept/alaya-vijnana-store",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "ālaya-vijñāna (store-consciousness)",
      "alternateName": [
        {"@value": "ālaya-vijñāna — Yogācāra storehouse consciousness with seeds (bīja)", "@language": "en"},
        {"@value": "阿賴耶識（唯識の種子蔵としての根本識）", "@language": "ja"}
      ],
      "description": "Yogācāra's eighth consciousness storing karmic seeds (bīja). Maps onto generative-model substrate in predictive processing; functional parallel to Theravāda bhavaṅga but with active causal role.",
      "mapsTo": [{"@id": "ans:framework/pp", "evidenceQuality": "strong"}, {"@id": "ans:framework/fep", "evidenceQuality": "moderate"}]
    },
    {
      "@id": "ans:concept/manas-ego-clinging",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "manas (ego-clinging)",
      "alternateName": [
        {"@value": "manas — seventh consciousness, persistent ego-clinging onto ālaya", "@language": "en"},
        {"@value": "末那識（恒常的自我執着としての第七識）", "@language": "ja"}
      ],
      "description": "Yogācāra's seventh consciousness that misapprehends ālaya as a self. Structural parallel to Metzinger's Phenomenal Self-Model (PSM).",
      "mapsTo": {"@id": "ans:framework/ast", "evidenceQuality": "moderate"}
    },
    {
      "@id": "ans:concept/bhavanga-continuum",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "bhavaṅga (life-continuum)",
      "alternateName": [
        {"@value": "bhavaṅga — Theravāda subliminal stream between cognitive processes", "@language": "en"},
        {"@value": "有分（上座部：認識過程の合間に流れる潜在的心）", "@language": "ja"}
      ],
      "description": "Subliminal continuity-stream that runs between citta-vīthi cycles. Functional parallel to ālaya-vijñāna but passive (no causal role)."
    },
    {
      "@id": "ans:concept/four-bhagas",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "four bhāgas",
      "alternateName": [
        {"@value": "four bhāgas — nimitta, darśana, svasaṃvitti, svasaṃvitti-saṃvitti", "@language": "en"},
        {"@value": "四分（相分・見分・自証分・証自証分）", "@language": "ja"}
      ],
      "description": "Yogācāra's analysis of every cognitive act into four moments: object-image (nimitta-bhāga), seeing-part (darśana-bhāga), self-cognition (svasaṃvitti), and meta-self-cognition. Parallels Sandved-Smith et al.'s hierarchical model of meta-awareness.",
      "mapsTo": {"@id": "ans:framework/fep", "evidenceQuality": "moderate"}
    },
    {
      "@id": "ans:concept/samprayoga",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "saṃprayoga (mental-factor concurrence)",
      "alternateName": [
        {"@value": "saṃprayoga — Sarvāstivāda's parallel concurrence of mental factors", "@language": "en"},
        {"@value": "相応（さまざまな心所が並列的に同時生起する有部の機制）", "@language": "ja"}
      ],
      "description": "In Sarvāstivāda, citta and caitta arise simultaneously in parallel — basis for the PDP mapping.",
      "mapsTo": {"@id": "ans:framework/pdp", "evidenceQuality": "strong"}
    },
    {
      "@id": "ans:concept/samanantara-pratyaya",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "samanantara-pratyaya (immediate-antecedent condition)",
      "alternateName": [
        {"@value": "samanantara-pratyaya — immediate-antecedent condition linking consecutive citta-moments", "@language": "en"},
        {"@value": "等無間縁（前刹那の心が次刹那の心の生起条件となる縁）", "@language": "ja"}
      ],
      "description": "Sarvāstivāda's solution to inter-moment continuity without an enduring self."
    },
    {
      "@id": "ans:concept/three-time-realism",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "three-time realism",
      "alternateName": [
        {"@value": "three-time realism (sarvāstivāda) — past/present/future dharmas are all real", "@language": "en"},
        {"@value": "三世実有（過去・現在・未来の法はいずれも実在）", "@language": "ja"}
      ],
      "description": "Sarvāstivāda's distinctive doctrine that all three time-periods of a dharma have ontological reality — only the 'activity' (kāritra) differs."
    },
    {
      "@id": "ans:concept/ksanikatva",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "kṣaṇikatva (momentariness)",
      "alternateName": [
        {"@value": "kṣaṇikatva — doctrine of momentary existence", "@language": "en"},
        {"@value": "刹那滅論（あらゆる存在は刹那ごとに生滅する）", "@language": "ja"}
      ],
      "description": "Universal Abhidharma doctrine that all conditioned dharmas exist only for a single moment (kṣaṇa). Convergence point with VanRullen & Koch's ~10 Hz discrete perceptual frames.",
      "mapsTo": {"@id": "ans:framework/neurophenomenology", "evidenceQuality": "moderate"}
    },
    {
      "@id": "ans:concept/svabhava",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "svabhāva (intrinsic nature)",
      "alternateName": [
        {"@value": "svabhāva — intrinsic nature; Sarvāstivāda realism vs. Madhyamaka critique", "@language": "en"},
        {"@value": "自性（svabhāva）—有部の本性実在論／中観派の批判対象", "@language": "ja"}
      ],
      "description": "Each dharma's defining characteristic. Central topic in the Sautrāntika and Madhyamaka critiques of Sarvāstivāda realism."
    },
    {
      "@id": "ans:concept/pratityasamutpada",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "pratītyasamutpāda (dependent origination)",
      "alternateName": [
        {"@value": "pratītyasamutpāda — dependent co-arising; Theravāda 24 paccaya is the most elaborated framework", "@language": "en"},
        {"@value": "縁起（pratītyasamutpāda）；上座部の24縁が最も精緻", "@language": "ja"}
      ],
      "description": "All phenomena arise dependent on conditions. Macy 1991 reads as systems-theoretic mutual causation."
    },
    {
      "@id": "ans:concept/anatman",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "anātman (non-self)",
      "alternateName": [
        {"@value": "anātman — no enduring self; the project's titular thesis", "@language": "en"},
        {"@value": "無我（あらゆる現象に恒常な「私」はない）—本プロジェクトの中核命題", "@language": "ja"}
      ],
      "description": "Core Buddhist doctrine: there is no enduring self underlying experience. The project's title 'Attention, Not Self' follows Ganeri in foregrounding attention as the organizing principle in place of self."
    },
    {
      "@id": "ans:concept/karmic-valence",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "karmic valence (kuśala / akuśala)",
      "alternateName": [
        {"@value": "karmic valence — wholesomeness/unwholesomeness as primitive evaluative property", "@language": "en"},
        {"@value": "業の善悪価（kuśala / akuśala）—計算論では捉えにくい根源的評価次元", "@language": "ja"}
      ],
      "description": "One of the 'hard limits' of computational mapping: Abhidharma encodes ethical valence at the level of individual dharmas, whereas computational frameworks have no analog at the basic level."
    },
    {
      "@id": "ans:concept/vipaka",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "vipāka (karmic ripening)",
      "alternateName": [
        {"@value": "vipāka — karmic ripening; how past intention shapes present experience", "@language": "en"},
        {"@value": "異熟（vipāka）—過去の意志が現在の経験を生成する仕組み", "@language": "ja"}
      ],
      "description": "Yogācāra's account: bīja stored in ālaya ripen into present cognitive moments. Functional parallel to generative-model prior weighting."
    },
    {
      "@id": "ans:concept/bija",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "bīja (seed)",
      "alternateName": [
        {"@value": "bīja — seeds stored in ālaya-vijñāna; carrier of karmic causation", "@language": "en"},
        {"@value": "種子（bīja）—阿賴耶識に蔵される業のキャリア", "@language": "ja"}
      ],
      "description": "Yogācāra's unit of karmic potency stored in ālaya. Maps onto parameters/priors of a generative model."
    },
    {
      "@id": "ans:concept/vasana",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "vāsanā (perfuming / habit-energy)",
      "alternateName": [
        {"@value": "vāsanā — habit-energy that perfumes the ālaya through repeated action", "@language": "en"},
        {"@value": "薫習（vāsanā）—行為の反復が阿賴耶識に痕跡を残す機制", "@language": "ja"}
      ],
      "description": "How conscious cognitive acts deposit dispositions into ālaya. Functional parallel to gradient updates of learned representations."
    },
    {
      "@id": "ans:concept/vijnaptimatrata",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "vijñaptimātratā (consciousness-only)",
      "alternateName": [
        {"@value": "vijñaptimātratā — Yogācāra's 'consciousness-only' doctrine; not metaphysical idealism (per Lusthaus 2002)", "@language": "en"},
        {"@value": "唯識性（vijñaptimātratā）—形而上的観念論ではなく認識批判（Lusthaus 2002）", "@language": "ja"}
      ],
      "description": "Yogācāra's analytical stance that experience is exhaustively explicable in terms of consciousness-events. Lusthaus reads as 'critique of consciousness,' rejecting the idealist misreading."
    },
    {
      "@id": "ans:concept/ashraya-paravritti",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "āśraya-parāvṛtti (revolution of the basis)",
      "alternateName": [
        {"@value": "āśraya-parāvṛtti — Yogācāra's 'turning of the basis'; soteriological transformation of ālaya", "@language": "en"},
        {"@value": "転依（āśraya-parāvṛtti）—唯識における阿賴耶識の根本的転換", "@language": "ja"}
      ],
      "description": "The soteriological event where ālaya is purified and converted into pure wisdom. Parallels self-model collapse in active inference accounts of ego dissolution (Deane 2021).",
      "mapsTo": {"@id": "ans:framework/fep", "evidenceQuality": "speculative"}
    },
    {
      "@id": "ans:concept/tathata-thusness",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "tathatā (thusness)",
      "alternateName": [
        {"@value": "tathatā — Mahāyāna's ultimate nature; the way things are", "@language": "en"},
        {"@value": "真如（tathatā）—大乗における究極的実在の本性", "@language": "ja"}
      ],
      "description": "The unconditioned suchness of phenomena; in Yogācāra, the ultimate referent of vijñaptimātratā insight."
    },
    {
      "@id": "ans:concept/nirvana",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "nirvāṇa / nibbāna",
      "alternateName": [
        {"@value": "nirvāṇa — cessation of suffering; one of the 'hard limits' of computational mapping", "@language": "en"},
        {"@value": "涅槃（nirvāṇa / nibbāna）—苦の終息；計算論的マッピングの限界点の一つ", "@language": "ja"}
      ],
      "description": "Theravāda's sole unconditioned dharma; soteriological telos. Resists computational analog because it is defined precisely as non-conditioned."
    },
    {
      "@id": "ans:concept/sati-mindfulness",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "sati (mindfulness)",
      "alternateName": [
        {"@value": "sati — Pāli technical term collapsed into Western 'mindfulness' (Nyanaponika 1962 → MBSR 1979)", "@language": "en"},
        {"@value": "念（sati）—西欧で「マインドフルネス」として包括された技術的術語", "@language": "ja"}
      ],
      "description": "Buddhist technical term for present-moment recollection. Genealogical study tracks Rhys Davids 1881 → Nyanaponika's 'bare attention' 1962 → Kabat-Zinn's MBSR 1979 → Sam Harris's Waking Up app."
    },
    {
      "@id": "ans:concept/sampajanna",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "sampajañña (clear comprehension)",
      "alternateName": [
        {"@value": "sampajañña — clear comprehension; paired with sati but distinct in function", "@language": "en"},
        {"@value": "正知（sampajañña）—念とペアで現れるが機能的に区別される", "@language": "ja"}
      ],
      "description": "Often conflated with sati in popular discourse. Genealogy essay disentangles the two."
    },
    {
      "@id": "ans:concept/bare-attention",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "bare attention (Nyanaponika 1962)",
      "alternateName": [
        {"@value": "bare attention — Nyanaponika's translation of sati that re-shaped modern mindfulness", "@language": "en"},
        {"@value": "純粋な気づき（bare attention）—Nyanaponika 1962 の翻訳が近代マインドフルネスを形作った", "@language": "ja"}
      ],
      "description": "Coined in *The Heart of Buddhist Meditation* (1962). Genealogy traces its journey from Theravāda monasticism through Esalen, est, NLP, and into MBSR."
    },
    {
      "@id": "ans:concept/rigpa",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "rigpa (Dzogchen non-dual awareness)",
      "alternateName": [
        {"@value": "rigpa — Tibetan Dzogchen's non-dual primordial awareness", "@language": "en"},
        {"@value": "リクパ（rigpa）—チベット・ゾクチェン伝統における非二元的根源的気づき", "@language": "ja"}
      ],
      "description": "Often conflated with sati in contemporary discourse (especially Sam Harris's Waking Up app). The genealogy essay's typology includes this as one of the ten confusions."
    },
    {
      "@id": "ans:concept/appamada-heedfulness",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "appamāda (heedfulness)",
      "alternateName": [
        {"@value": "appamāda — heedfulness / diligence; Buddha's last word", "@language": "en"},
        {"@value": "不放逸（appamāda）—仏陀の遺言とされる徳目", "@language": "ja"}
      ],
      "description": "Frequently absent from the modern 'awareness' vocabulary despite being central in early Buddhism. Genealogy essay restores it to the typology."
    },
    {
      "@id": "ans:concept/jagariya",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "jāgariya (wakefulness)",
      "alternateName": [
        {"@value": "jāgariya — wakefulness; another technical term often collapsed into 'awareness'", "@language": "en"},
        {"@value": "覚醒（jāgariya）—「awareness」に包括されてしまう技術的術語の一つ", "@language": "ja"}
      ],
      "description": "Part of the genealogy essay's ten-term typology that recovers distinctions the single word 'awareness' / 気づき has flattened."
    },
    {
      "@id": "ans:concept/precision-weighting",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "precision-weighting",
      "alternateName": [
        {"@value": "precision-weighting — predictive-processing mechanism for attention (inverse-variance of prediction errors)", "@language": "en"},
        {"@value": "精度重み付け（precision-weighting）—予測符号化における注意の機制", "@language": "ja"}
      ],
      "description": "In active inference, attention is modeled as precision-weighting of prediction-error signals. Confirmed by Tal et al. 2025 as the common mechanism across computational meditation models.",
      "mapsTo": "ans:framework/pp"
    },
    {
      "@id": "ans:concept/meta-awareness",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "meta-awareness",
      "alternateName": [
        {"@value": "meta-awareness — hierarchical AIF model of awareness of awareness (Sandved-Smith et al. 2021)", "@language": "en"},
        {"@value": "メタ気づき（meta-awareness）—気づきへの気づきの階層的AIFモデル", "@language": "ja"}
      ],
      "description": "Deep parametric active inference model. Parallels Yogācāra's svasaṃvitti / svasaṃvitti-saṃvitti distinction."
    },
    {
      "@id": "ans:concept/ego-dissolution",
      "@type": ["ans:Concept", "schema:DefinedTerm"],
      "name": "ego dissolution",
      "alternateName": [
        {"@value": "ego dissolution — self-model collapse under psychedelics or deep meditation (Deane 2021)", "@language": "en"},
        {"@value": "自我溶解（ego dissolution）—サイケデリクスや深い瞑想下での自己モデル崩壊", "@language": "ja"}
      ],
      "description": "Active-inference account where the phenomenal self-model temporarily destabilizes. Parallels Yogācāra's āśraya-parāvṛtti."
    },

    {
      "@id": "ans:framework/gwt",
      "@type": ["ans:Framework", "schema:DefinedTerm"],
      "name": "Global Workspace Theory",
      "alternateName": [
        {"@value": "Global Workspace Theory (GWT) — Baars 1988", "@language": "en"},
        {"@value": "グローバル・ワークスペース理論（GWT, Baars 1988）", "@language": "ja"}
      ],
      "description": "Cognitive theory: consciousness emerges from broadcast of selected content to a global workspace. Strongest mapping to Theravāda citta-vīthi's serial all-or-nothing javana ignition.",
      "citation": ["ans:ref/baars-1988", "ans:ref/dehaene-naccache-2001"]
    },
    {
      "@id": "ans:framework/gnw",
      "@type": ["ans:Framework", "schema:DefinedTerm"],
      "name": "Global Neuronal Workspace",
      "alternateName": [
        {"@value": "Global Neuronal Workspace (GNW) — Dehaene & Naccache 2001 neural implementation of GWT", "@language": "en"},
        {"@value": "グローバル・ニューロナル・ワークスペース（GNW, Dehaene & Naccache 2001）", "@language": "ja"}
      ],
      "description": "Neural implementation of GWT. All-or-nothing ignition closely parallels javana cascade in citta-vīthi.",
      "citation": "ans:ref/dehaene-naccache-2001"
    },
    {
      "@id": "ans:framework/pp",
      "@type": ["ans:Framework", "schema:DefinedTerm"],
      "name": "Predictive Processing",
      "alternateName": [
        {"@value": "Predictive Processing (PP) — Clark 2016, Hohwy 2013", "@language": "en"},
        {"@value": "予測符号化（Predictive Processing, Clark 2016 / Hohwy 2013）", "@language": "ja"}
      ],
      "description": "The brain as a hierarchical prediction machine. Maps onto Yogācāra ālaya-vijñāna (generative model) and manaskāra (precision-weighting).",
      "citation": ["ans:ref/clark-2016", "ans:ref/hohwy-2013"]
    },
    {
      "@id": "ans:framework/fep",
      "@type": ["ans:Framework", "schema:DefinedTerm"],
      "name": "Free Energy Principle / Active Inference",
      "alternateName": [
        {"@value": "Free Energy Principle / Active Inference (FEP / AIF) — Friston 2010", "@language": "en"},
        {"@value": "自由エネルギー原理／能動推論（FEP / AIF, Friston 2010）", "@language": "ja"}
      ],
      "description": "Unified brain theory: all biological systems minimize variational free energy. AIF extends to action. Maps onto Yogācāra cognition and Sandved-Smith's hierarchical meta-awareness.",
      "citation": ["ans:ref/friston-2010", "ans:ref/friston-2018"]
    },
    {
      "@id": "ans:framework/iit",
      "@type": ["ans:Framework", "schema:DefinedTerm"],
      "name": "Integrated Information Theory",
      "alternateName": [
        {"@value": "Integrated Information Theory (IIT) — Tononi", "@language": "en"},
        {"@value": "統合情報理論（IIT, Tononi）", "@language": "ja"}
      ],
      "description": "Consciousness = integrated information (Φ). Weaker mapping to Abhidharma; discussed mainly for completeness."
    },
    {
      "@id": "ans:framework/pdp",
      "@type": ["ans:Framework", "schema:DefinedTerm"],
      "name": "Parallel Distributed Processing",
      "alternateName": [
        {"@value": "Parallel Distributed Processing (PDP) — McClelland & Rumelhart 1986", "@language": "en"},
        {"@value": "並列分散処理（PDP, McClelland & Rumelhart 1986）", "@language": "ja"}
      ],
      "description": "Cognition as parallel activation across distributed units. Strongest mapping to Sarvāstivāda saṃprayoga (mental factors firing concurrently)."
    },
    {
      "@id": "ans:framework/ast",
      "@type": ["ans:Framework", "schema:DefinedTerm"],
      "name": "Attention Schema Theory",
      "alternateName": [
        {"@value": "Attention Schema Theory (AST) — Graziano", "@language": "en"},
        {"@value": "注意スキーマ理論（AST, Graziano）", "@language": "ja"}
      ],
      "description": "Consciousness as the brain's internal model of its own attention. Structural parallel to Yogācāra manas / svasaṃvitti."
    },
    {
      "@id": "ans:framework/neurophenomenology",
      "@type": ["ans:Framework", "schema:DefinedTerm"],
      "name": "Neurophenomenology",
      "alternateName": [
        {"@value": "Neurophenomenology — Varela 1996", "@language": "en"},
        {"@value": "神経現象学（Varela 1996）", "@language": "ja"}
      ],
      "description": "First-person phenomenological reports + third-person neural data, with mindfulness-Buddhism connection.",
      "citation": "ans:ref/varela-1996"
    },
    {
      "@id": "ans:framework/comp-phenomenology",
      "@type": ["ans:Framework", "schema:DefinedTerm"],
      "name": "Computational Phenomenology",
      "alternateName": [
        {"@value": "Computational Phenomenology — Ramstead 2022 / Sandved-Smith 2024 five-level framework", "@language": "en"},
        {"@value": "計算論的現象学（Ramstead 2022 / Sandved-Smith 2024 の5段階フレームワーク）", "@language": "ja"}
      ],
      "description": "Methodology connecting phenomenological description to mathematical models (Bayesian mechanics). The project's primary computational interlocutor.",
      "citation": ["ans:ref/ramstead-2022", "ans:ref/sandved-smith-2024"]
    },

    {"@id": "ans:ref/ganeri-2017", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Ganeri 2017", "alternateName": [{"@value": "Ganeri, J. Attention, Not Self. Oxford University Press, 2017.", "@language": "en"}], "description": "Project namesake; attention-first reading of Buddhaghosa's Abhidhamma."},
    {"@id": "ans:ref/karunadasa-2010", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Karunadasa 2010", "alternateName": [{"@value": "Karunadasa, Y. The Theravāda Abhidhamma. Wisdom Publications, 2010.", "@language": "en"}], "description": "Authoritative survey of Theravāda Abhidhamma; reconstructive reading of citta-vīthi."},
    {"@id": "ans:ref/ronkin-2005", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Ronkin 2005", "alternateName": [{"@value": "Ronkin, N. Early Buddhist Metaphysics. RoutledgeCurzon, 2005.", "@language": "en"}], "description": "Time-scale reduction framework; svabhāva dynamic-vs-substantialist debate."},
    {"@id": "ans:ref/cox-1995", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Cox 1995", "alternateName": [{"@value": "Cox, C. Disputed Dharmas: Early Buddhist Theories on Existence. ICPBS, 1995.", "@language": "en"}], "description": "Sarvāstivāda intrinsic-nature realism (svabhāva) and its critics."},
    {"@id": "ans:ref/dhammajoti-2009", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Dhammajoti 2009", "alternateName": [{"@value": "Dhammajoti, KL. Sarvāstivāda Abhidharma. Centre of Buddhist Studies, HK, 2009.", "@language": "en"}], "description": "Standard reference on Sarvāstivāda doctrine; 'dharmas weak alone, active together.'"},
    {"@id": "ans:ref/lusthaus-2002", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Lusthaus 2002", "alternateName": [{"@value": "Lusthaus, D. Buddhist Phenomenology. RoutledgeCurzon, 2002.", "@language": "en"}], "description": "Reads Yogācāra as a 'critique of consciousness,' rejecting the idealist misreading."},
    {"@id": "ans:ref/waldron-2003", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Waldron 2003", "alternateName": [{"@value": "Waldron, W. The Buddhist Unconscious: The Ālaya-vijñāna. RoutledgeCurzon, 2003.", "@language": "en"}], "description": "Ālaya as unconscious substrate; simultaneity of the eight consciousnesses."},
    {"@id": "ans:ref/sharf-2016", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Sharf 2016", "alternateName": [{"@value": "Sharf, R. 'Is Yogācāra Phenomenology?' Journal of Indian Philosophy, 2016.", "@language": "en"}], "description": "Argues against a Husserlian reading of the four bhāgas."},
    {"@id": "ans:ref/arnold-2012", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Arnold 2012", "alternateName": [{"@value": "Arnold, D. Brains, Buddhas, and Believing. Columbia University Press, 2012.", "@language": "en"}], "description": "Transcendental (not phenomenological) reading of svasaṃvitti."},
    {"@id": "ans:ref/ramstead-2022", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Ramstead 2022", "alternateName": [{"@value": "Ramstead, M. et al. 'From Generative Models to Generative Passages.' Review of Philosophy and Psychology, 2022.", "@language": "en"}], "description": "Foundational paper on computational phenomenology methodology."},
    {"@id": "ans:ref/sandved-smith-2024", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Sandved-Smith 2024", "alternateName": [{"@value": "Sandved-Smith, L. et al. Five-level framework (A1–A5) for computational neurophenomenology, 2024.", "@language": "en"}], "description": "Phenomenology-to-mathematics circulation; Bayesian mechanics."},
    {"@id": "ans:ref/varela-1996", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Varela 1996", "alternateName": [{"@value": "Varela, F. 'Neurophenomenology: A Methodological Remedy for the Hard Problem.' Journal of Consciousness Studies, 1996.", "@language": "en"}], "description": "Foundational neurophenomenology paper; mindfulness-Buddhism connection."},
    {"@id": "ans:ref/tal-2025", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Tal et al. 2025", "alternateName": [{"@value": "Tal, Wright, Prest, Sandved-Smith, Sacchet (Harvard/MGH). Review of computational meditation models, 2025.", "@language": "en"}], "description": "Confirms precision-weighting as common mechanism across meditation models."},
    {"@id": "ans:ref/friston-2010", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Friston 2010", "alternateName": [{"@value": "Friston, K. 'The free-energy principle: a unified brain theory?' Nature Reviews Neuroscience, 2010.", "@language": "en"}], "description": "Foundational FEP paper."},
    {"@id": "ans:ref/friston-2018", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Friston 2018", "alternateName": [{"@value": "Friston, K. 'Am I self-conscious?' Frontiers in Psychology, 2018.", "@language": "en"}], "description": "Self-evidencing as source of minimal self-modeling."},
    {"@id": "ans:ref/clark-2016", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Clark 2016", "alternateName": [{"@value": "Clark, A. Surfing Uncertainty. Oxford UP, 2016.", "@language": "en"}], "description": "Canonical exposition of predictive processing."},
    {"@id": "ans:ref/hohwy-2013", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Hohwy 2013", "alternateName": [{"@value": "Hohwy, J. The Predictive Mind. Oxford UP, 2013.", "@language": "en"}], "description": "Companion canonical treatment of PP."},
    {"@id": "ans:ref/metzinger-2003", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Metzinger 2003", "alternateName": [{"@value": "Metzinger, T. Being No One: The Self-Model Theory of Subjectivity. MIT Press, 2003.", "@language": "en"}], "description": "Phenomenal Self-Model (PSM); structural parallel to Yogācāra manas."},
    {"@id": "ans:ref/hoffman-2015", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Hoffman 2015", "alternateName": [{"@value": "Hoffman, D. 'The Interface Theory of Perception.' Current Directions in Psychological Science, 2015.", "@language": "en"}], "description": "Perception as fitness-tuned user interface."},
    {"@id": "ans:ref/dehaene-naccache-2001", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Dehaene & Naccache 2001", "alternateName": [{"@value": "Dehaene, S. & Naccache, L. 'Towards a cognitive neuroscience of consciousness.' Cognition, 2001.", "@language": "en"}], "description": "Global Neuronal Workspace; all-or-nothing ignition."},
    {"@id": "ans:ref/baars-1988", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Baars 1988", "alternateName": [{"@value": "Baars, B. A Cognitive Theory of Consciousness. Cambridge UP, 1988.", "@language": "en"}], "description": "Original Global Workspace Theory."},
    {"@id": "ans:ref/posner-petersen-1990", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Posner & Petersen 1990", "alternateName": [{"@value": "Posner, M. & Petersen, S. 'The attention system of the human brain.' Annual Review of Neuroscience, 1990.", "@language": "en"}], "description": "Three attention networks: alerting / orienting / executive."},
    {"@id": "ans:ref/vanrullen-koch-2003", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "VanRullen & Koch 2003", "alternateName": [{"@value": "VanRullen, R. & Koch, C. 'Is perception discrete or continuous?' TICS, 2003.", "@language": "en"}], "description": "Discrete perceptual frames (~10 Hz); convergence with kṣaṇa-vāda."},
    {"@id": "ans:ref/macy-1991", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Macy 1991", "alternateName": [{"@value": "Macy, J. Mutual Causality in Buddhism and General Systems Theory. SUNY Press, 1991.", "@language": "en"}], "description": "Pratītyasamutpāda as systems-theoretic mutual causation."},
    {"@id": "ans:ref/deane-2021", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Deane 2021", "alternateName": [{"@value": "Deane, G. Active inference accounts of ego dissolution under psychedelics and deep meditation, 2021.", "@language": "en"}], "description": "Self-model collapse parallels āśraya-parāvṛtti."},
    {"@id": "ans:ref/sandved-smith-2021", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Sandved-Smith et al. 2021", "alternateName": [{"@value": "Sandved-Smith, Hesp, Mattout, Friston, Lutz, Ramstead. Hierarchical model of meta-awareness, 2021.", "@language": "en"}], "description": "Deep parametric AIF; parallels 自証分 / 証自証分 distinction."},
    {"@id": "ans:ref/laukkonen-slagter-2021", "@type": ["ans:Reference", "schema:ScholarlyArticle"], "name": "Laukkonen & Slagter 2021", "alternateName": [{"@value": "Laukkonen, R. & Slagter, H. 'From many to (n)one.' Neuroscience & Biobehavioral Reviews, 2021.", "@language": "en"}], "description": "FA / OM / ND meditation as precision-modulation stages."},
