    {
      "@id": "ans:tradition/theravada",
      "@type": ["ans:Tradition", "schema:DefinedTerm"],
      "name": "Theravāda",
      "alternateName": [
        {"@value": "Theravāda Abhidhamma (82 dhammas, Pāli canon)", "@language": "en"},
        {"@value": "上座部仏教（パーリ語、82法）", "@language": "ja"}
      ],
      "description": "South/Southeast Asian Abhidhamma tradition. Pāli canon. Distinguishing features: 17-moment citta-vīthi, bhavaṅga (life-continuum), 82 dhammas with nibbāna as the sole unconditioned."
    },
    {
      "@id": "ans:tradition/sarvastivada",
      "@type": ["ans:Tradition", "schema:DefinedTerm"],
      "name": "Sarvāstivāda",
      "alternateName": [
        {"@value": "Sarvāstivāda Abhidharma (75 dharmas, Sanskrit/Chinese)", "@language": "en"},
        {"@value": "説一切有部（サンスクリット／漢訳、75法）", "@language": "ja"}
      ],
      "description": "North Indian Abhidharma tradition. 75 dharmas across 5 categories. Distinguishing features: three-time realism (三世実有), saṃprayoga + samanantara-pratyaya, intrinsic-nature (svabhāva) doctrine."
    },
    {
      "@id": "ans:tradition/yogacara",
      "@type": ["ans:Tradition", "schema:DefinedTerm"],
      "name": "Yogācāra",
      "alternateName": [
        {"@value": "Yogācāra / Vijñānavāda (100 dharmas)", "@language": "en"},
        {"@value": "瑜伽行唯識学派（100法）", "@language": "ja"}
      ],
      "description": "Mahāyāna Abhidharma tradition. 100 dharmas. Distinguishing features: eight consciousnesses (ālaya-vijñāna + manas + 6 sense-consciousnesses), four-bhāga structure, vijñaptimātratā (consciousness-only)."
    },

    {
      "@id": "ans:category/rupa",
      "@type": ["ans:DharmaCategory", "schema:DefinedTerm"],
      "name": "rūpa (form / matter)",
      "alternateName": [
        {"@value": "rūpa — material form", "@language": "en"},
        {"@value": "色法（物質）", "@language": "ja"}
      ],
      "description": "Material/physical dharmas: sense organs, sense objects, four great elements."
    },
    {
      "@id": "ans:category/citta",
      "@type": ["ans:DharmaCategory", "schema:DefinedTerm"],
      "name": "citta (mind / consciousness)",
      "alternateName": [
        {"@value": "citta — consciousness moments", "@language": "en"},
        {"@value": "心法（心・識）", "@language": "ja"}
      ],
      "description": "Consciousness itself. Sarvāstivāda: 1 dharma. Yogācāra: 8 vijñānas. Theravāda: 89/121 types of citta."
    },
    {
      "@id": "ans:category/caitta-universal",
      "@type": ["ans:DharmaCategory", "schema:DefinedTerm"],
      "name": "universal mental factors",
      "alternateName": [
        {"@value": "caitta — universal mental factors (sarvatraga / sabbacittasādhāraṇa)", "@language": "en"},
        {"@value": "心所法・遍行（全心に伴う）", "@language": "ja"}
      ],
      "description": "Mental factors present in every conscious moment. Sarvāstivāda mahābhūmika, Yogācāra sarvatraga, Theravāda sabbacittasādhāraṇa."
    },
    {
      "@id": "ans:category/caitta-object-determining",
      "@type": ["ans:DharmaCategory", "schema:DefinedTerm"],
      "name": "object-determining mental factors",
      "alternateName": [
        {"@value": "caitta — object-determining (viniyata / pakiṇṇaka)", "@language": "en"},
        {"@value": "心所法・別境（対象限定）", "@language": "ja"}
      ],
      "description": "Mental factors that arise only with specific objects. Yogācāra biekjing (別境)."
    },
    {
      "@id": "ans:category/caitta-wholesome",
      "@type": ["ans:DharmaCategory", "schema:DefinedTerm"],
      "name": "wholesome mental factors",
      "alternateName": [
        {"@value": "caitta — wholesome (kuśala / sobhana)", "@language": "en"},
        {"@value": "心所法・善", "@language": "ja"}
      ],
      "description": "Wholesome/skillful mental factors. Sarvāstivāda kuśala-mahābhūmika, Theravāda sobhana."
    },
    {
      "@id": "ans:category/caitta-affliction",
      "@type": ["ans:DharmaCategory", "schema:DefinedTerm"],
      "name": "primary afflictions",
      "alternateName": [
        {"@value": "caitta — primary afflictions (kleśa / mūla-kleśa)", "@language": "en"},
        {"@value": "心所法・根本煩悩", "@language": "ja"}
      ],
      "description": "Root afflictions: greed, hatred, delusion, pride, doubt, wrong view."
    },
    {
      "@id": "ans:category/caitta-secondary-affliction",
      "@type": ["ans:DharmaCategory", "schema:DefinedTerm"],
      "name": "secondary afflictions",
      "alternateName": [
        {"@value": "caitta — secondary afflictions (upakleśa)", "@language": "en"},
        {"@value": "心所法・随煩悩", "@language": "ja"}
      ],
      "description": "Derivative afflictions: anger, hypocrisy, jealousy, envy, etc."
    },
    {
      "@id": "ans:category/caitta-variable",
      "@type": ["ans:DharmaCategory", "schema:DefinedTerm"],
      "name": "variable mental factors",
      "alternateName": [
        {"@value": "caitta — variable / indeterminate (aniyata)", "@language": "en"},
        {"@value": "心所法・不定", "@language": "ja"}
      ],
      "description": "Mental factors that may be wholesome or unwholesome: vitarka, vicāra, kaukṛtya, middha."
    },
    {
      "@id": "ans:category/cittaviprayukta",
      "@type": ["ans:DharmaCategory", "schema:DefinedTerm"],
      "name": "non-associated formations",
      "alternateName": [
        {"@value": "cittaviprayukta-saṃskāra — formations not associated with mind", "@language": "en"},
        {"@value": "心不相応行法", "@language": "ja"}
      ],
      "description": "Conditioned dharmas neither material nor mental: prāpti, jāti, sthiti, anityatā, life-faculty, etc. Sarvāstivāda 14, Yogācāra 24. Theravāda denies the category."
    },
    {
      "@id": "ans:category/asamskrta",
      "@type": ["ans:DharmaCategory", "schema:DefinedTerm"],
